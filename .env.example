# Fluxer Bot Configuration
# ========================

# Your Fluxer bot token (create a bot application in your Fluxer instance)
FLUXER_BOT_TOKEN=your-bot-token-here

# The base URL of your Fluxer instance (no trailing slash)
# Examples: https://fluxer.app, https://your-selfhosted-instance.com
FLUXER_BASE_URL=https://fluxer.app

# LiveKit Configuration
# These are from your Fluxer instance's LiveKit setup
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Bot Settings
BOT_PREFIX=!